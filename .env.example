# .env.example
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.
# This file IS safe to commit — it contains no real secrets.
#
# Group variables by concern. Add project-specific variables below each group.

# ─── Application ────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development         # development | staging | production
APP_URL=http://localhost:3000

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# DATABASE_POOL_SIZE=10

# ─── Authentication ─────────────────────────────────────────────────────────
AUTH_JWT_SECRET=change-me-in-production
# AUTH_SESSION_TTL=86400       # seconds (default: 24h)

# ─── Email / SMTP ───────────────────────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ─── Storage ────────────────────────────────────────────────────────────────
# STORAGE_BUCKET=
# STORAGE_REGION=

# ─── AI Provider (if applicable) ────────────────────────────────────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ─── Third-party Integrations ───────────────────────────────────────────────
# Add service-specific keys here, e.g.:
# STRIPE_SECRET_KEY=
# SENDGRID_API_KEY=

# ─── Feature Flags ──────────────────────────────────────────────────────────
# FEATURE_NEW_DASHBOARD=false
