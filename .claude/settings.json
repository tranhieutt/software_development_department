{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "statusLine": {
    "type": "command",
    "command": "bash .claude/statusline.sh"
  },
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git rev-parse*)",
      "Bash(git show*)",
      "Bash(git stash list*)",
      "Bash(ls *)",
      "Bash(dir *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(tree *)",
      "Bash(npm list*)",
      "Bash(pip list*)",
      "Bash(npm run build*)",
      "Bash(npx tsc --noEmit*)",
      "Bash(python -m json.tool*)",
      "Bash(python -m pytest*)",
      "Bash(py -m pytest*)",
      "mcp__gitnexus__query(*)",
      "mcp__gitnexus__context(*)",
      "mcp__gitnexus__impact(*)",
      "mcp__gitnexus__detect_changes(*)",
      "mcp__gitnexus__list_repos(*)",
      "mcp__gitnexus__cypher(*)",
      "mcp__gitnexus__rename(*)",
      "Bash(npx gitnexus*)",
      "Bash(bash .claude/hooks/fork-join.sh *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -rf ./*)",
      "Bash(rm -rf .)",
      "Bash(rm -rf ./)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(sudo *)",
      "Bash(chmod 777*)",
      "Bash(*>.env)",
      "Bash(*>.env.*)",
      "Bash(*>.env*)",
      "Bash(cat .env)",
      "Bash(cat .env.*)",
      "Bash(cat *.env)",
      "Bash(cat *.env.*)",
      "Bash(type .env)",
      "Bash(type .env.*)",
      "Bash(type *.env*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.env*)",
      "Bash(curl *|*sh*)",
      "Bash(curl *|*bash*)",
      "Bash(wget *|*sh*)",
      "Bash(wget *|*bash*)",
      "Bash(*>.bashrc*)",
      "Bash(*>.zshrc*)",
      "Bash(*>.profile*)",
      "Bash(npm publish*)",
      "Bash(docker rm -f*)",
      "Bash(docker system prune*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/detect-gaps.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/prompt-context.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/persist-memory.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/bash-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/validate-commit.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/validate-push.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/circuit-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-refactor-impact.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/file-history.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/log-writes.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/validate-assets.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/log-commit.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/decision-ledger-writer.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/circuit-updater.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-compact.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-stop.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/log-agent.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}